{
  "name": "sonic-solana-autotrader",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sonic Solana Auto-Trader - Phase 1 Safe Foundation",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev:worker": "pnpm --filter @sonic/worker dev",
    "dev:telegram": "pnpm --filter @sonic/telegram-bot dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
