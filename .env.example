NODE_ENV=development
LOG_LEVEL=info
APP_MODE=READ_ONLY
APP_VERSION=0.1.0
SAFETY_PROFILE=strict
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
DATABASE_URL=./data/sonic.db

# Phase 4: Local SQLite audit database (not a secret — local filesystem path)
DATABASE_PATH=./data/sonic-solana-autotrader.sqlite

# Phase 4: Audit retention settings
# AUDIT_RETENTION_DAYS: delete events older than N days (1–365, default 30)
AUDIT_RETENTION_DAYS=30
# AUDIT_MAX_EVENTS: keep at most N events (100–1000000, default 10000)
AUDIT_MAX_EVENTS=10000
# AUDIT_ROTATION_ENABLED: set to false to disable retention/rotation
AUDIT_ROTATION_ENABLED=true

# Unsafe capability flags — all default false.
# Phase 4: even if set to true, these do NOT activate any unsafe functionality.
# Capabilities remain disabled. Flags are detected, warned about, and ignored.
ENABLE_LIVE_TRADING=false
ENABLE_AUTO_TRADING=false
ENABLE_TRANSACTION_SIGNING=false
ENABLE_TRANSACTION_SENDING=false
ENABLE_WALLET_LOADING=false
ENABLE_SOLANA_RPC=false
ENABLE_JITO=false
ENABLE_PUMPFUN_TRADING=false

# Unlock flags — do NOT unlock modes in Phase 4. Detected and warned.
FULL_AUTO_UNLOCKED=false
LIMITED_LIVE_UNLOCKED=false
